<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="AppEnfermagem.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:AppEnfermagem.Views"
    Shell.FlyoutBehavior="Disabled"
    Shell.NavBarIsVisible="False"
    Title="AppEnfermagem">

    <ShellContent
        Title="Inicio"
        ContentTemplate="{DataTemplate local:InicioPage}"
        Route="InicioPage" />

    <ShellContent
        Title="Apresentação"
        ContentTemplate="{DataTemplate local:ApresentacaoPage}"
        Route="ApresentacaoPage" />

    <ShellContent
        Title="Opcoes"
        ContentTemplate="{DataTemplate local:OpcoesPage}"
        Route="OpcoesPage" />

    <ShellContent
        Title="Suporte"
        ContentTemplate="{DataTemplate local:SuportePage}"
        Route="SuportePage" />

    <ShellContent
        Title="Ajuda"
        ContentTemplate="{DataTemplate local:AjudaPage}"
        Route="AjudaPage" />

    <ShellContent
        Title="Home"
        ContentTemplate="{DataTemplate local:HomePage}"
        Route="HomePage" />

</Shell>

