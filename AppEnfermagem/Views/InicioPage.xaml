<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AppEnfermagem.Views.InicioPage"
             BackgroundColor="#f8f8f8"
             NavigationPage.HasNavigationBar="False">

    <Grid>

        <VerticalStackLayout
            Spacing="40"
            HorizontalOptions="Center"
            VerticalOptions="Start"
            MaximumWidthRequest="480"
            Padding="20,128,20,40">

            <!-- LOGO -->
            <Grid WidthRequest="220"
                  HeightRequest="220"
                  HorizontalOptions="Center">
                <Image Source="logo.jpg"
                       Aspect="AspectFill"
                       WidthRequest="220"
                       HeightRequest="220">
                    <Image.Clip>
                        <EllipseGeometry Center="110,110"
                                         RadiusX="110"
                                         RadiusY="110" />
                    </Image.Clip>
                </Image>

                <Ellipse Stroke="#1a5276"
                         StrokeThickness="2"
                         Fill="Transparent"/>
            </Grid>

            <!-- FRASE -->
            <Label Text="“Seu guia no caminho de cuidar”"
                   FontSize="20"
                   FontAttributes="Italic"
                   TextColor="#004AAD"
                   HorizontalTextAlignment="Center"/>

            <!-- BOTÃO -->
            <Button x:Name="BtnConhecerButton"
                    Text="Conhecer"
                    BackgroundColor="#004AAD"
                    TextColor="White"
                    FontSize="16"
                    CornerRadius="25"
                    HeightRequest="48"
                    WidthRequest="200"
                    HorizontalOptions="Center"
                    Margin="0,60,0,0"
                    Clicked="OnConhecerClicked"/>

        </VerticalStackLayout>

    </Grid>
</ContentPage>
