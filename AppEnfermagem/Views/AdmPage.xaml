<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AppEnfermagem.Views.AdmPage"
             Title="AdmPage">
    <VerticalStackLayout>
        <Button Text="Sair"
                TextColor="#004AAD"
                BackgroundColor="#8EDDDE"
                BorderColor="Transparent"
                BorderWidth="1"
                FontSize="15"
                CornerRadius="20"
                FontAttributes="Bold"
                HeightRequest="45"
                WidthRequest="150"
                HorizontalOptions="Center"
                Margin="0,15,0,0"
                Command="{Binding SairCommand}" />
    </VerticalStackLayout>
</ContentPage>