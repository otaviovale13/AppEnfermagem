<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AppEnfermagem.Views.FormularioTopicoPage"
             xmlns:vm="clr-namespace:AppEnfermagem.ViewModels"
             x:DataType="vm:FormularioTopicoViewModel"
             BackgroundColor="#F8F8F8"
             Title="Novo Tópico">

    <Grid>
        <ScrollView Padding="25">
            <VerticalStackLayout Spacing="20">

                <Label Text="Nome da Categoria" 
                       TextColor="#333333"
                       FontSize="16"
                       FontAttributes="Bold"
                       Margin="5,0"/>

                <Border Stroke="#004AAD"
                        StrokeThickness="2"
                        BackgroundColor="White"
                        Padding="15,0"
                        StrokeShape="RoundRectangle 15"
                        HeightRequest="55">
                    <Grid ColumnDefinitions="*, Auto">
                        <Entry Text="{Binding NovoTopico.Name}" 
                               Placeholder="Ex: Cardiologia, Pediatria..."
                               PlaceholderColor="Gray"
                               TextColor="Black"
                               FontSize="16"
                               VerticalOptions="Center"
                               BackgroundColor="Transparent"/>

                        <Image Grid.Column="1" 
                               Source="pencil_icon.png" 
                               HeightRequest="22" 
                               VerticalOptions="Center"/>
                    </Grid>
                </Border>

                <Label Text="Dica: O ícone padrão de 'Pasta' será atribuído automaticamente. Você poderá editar a imagem no banco de dados posteriormente."
                       TextColor="Gray"
                       FontSize="12"
                       HorizontalTextAlignment="Center"
                       Margin="10,0"/>
                
                <Label Text="Descrição (Opcional)" TextColor="#333333" FontAttributes="Bold" Margin="5,0"/>
                <Border Stroke="#004AAD" StrokeThickness="2" BackgroundColor="White" Padding="15,0" StrokeShape="RoundRectangle 15" HeightRequest="100">
                    <Editor Text="{Binding NovoTopico.Description}" 
            Placeholder="Descreva brevemente esta categoria..."
            PlaceholderColor="Gray" TextColor="Black" FontSize="15" />
                </Border>

                <Label Text="Ordem de Exibição" TextColor="#333333" FontAttributes="Bold" Margin="5,0"/>
                <Border Stroke="#004AAD" StrokeThickness="2" BackgroundColor="White" Padding="15,0" StrokeShape="RoundRectangle 15" HeightRequest="55">
                    <Entry Text="{Binding NovoTopico.DisplayOrder}" 
           Keyboard="Numeric"
           Placeholder="Ex: 1"
           PlaceholderColor="Gray" TextColor="Black" FontSize="16" VerticalOptions="Center" />
                </Border>

                <Button Text="Criar Categoria" 
                        BackgroundColor="#004AAD" 
                        TextColor="White"
                        FontAttributes="Bold"
                        FontSize="16"
                        CornerRadius="30"
                        HeightRequest="55"
                        Margin="0,30,0,0"
                        Command="{Binding SalvarTopicoCommand}">
                    <Button.Shadow>
                        <Shadow Brush="Black" Offset="0,5" Radius="10" Opacity="0.1"/>
                    </Button.Shadow>
                </Button>

            </VerticalStackLayout>
        </ScrollView>
        <Grid BackgroundColor="#AA000000" 
              IsVisible="{Binding IsLoading}" 
              InputTransparent="False"
              HorizontalOptions="FillAndExpand" 
              VerticalOptions="FillAndExpand">

            <VerticalStackLayout VerticalOptions="Center" 
                                 HorizontalOptions="Center" 
                                 Spacing="15">

                <ActivityIndicator IsRunning="{Binding IsLoading}" 
                                   Color="White" 
                                   HeightRequest="50" 
                                   WidthRequest="50" />

                <Label Text="Carregando..." 
                       TextColor="White" 
                       FontSize="18"
                       FontAttributes="Bold" 
                       HorizontalTextAlignment="Center"/>
            </VerticalStackLayout>
        </Grid>
    </Grid>
</ContentPage>