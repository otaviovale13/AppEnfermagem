<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AppEnfermagem.Views.FormularioArtigoPage"
             xmlns:vm="clr-namespace:AppEnfermagem.ViewModels"
             x:DataType="vm:FormularioArtigoViewModel"
             BackgroundColor="#F8F8F8"
             Title="{Binding TituloPagina}">

    <ScrollView Padding="25">
        <VerticalStackLayout Spacing="20">

            <Label Text="Título do Artigo" 
       TextColor="#333333"
       FontSize="16"
       FontAttributes="Bold"
       Margin="5,0"/>

            <Border Stroke="#004AAD"
        StrokeThickness="2"
        BackgroundColor="White"
        Padding="15,0"
        StrokeShape="RoundRectangle 15"
        HeightRequest="50">
                <Grid ColumnDefinitions="*, Auto">
                    <Entry Text="{Binding Artigo.Title}" 
               Placeholder="Ex: Protocolo de Higienização"
               PlaceholderColor="Gray"
               TextColor="Black"
               FontSize="15"
               VerticalOptions="Center"
               BackgroundColor="Transparent"/>

                    <Image Grid.Column="1" 
               Source="pencil_icon.png" 
               HeightRequest="20" 
               WidthRequest="20"
               VerticalOptions="Center"/>
                </Grid>
            </Border>

            <Label Text="Categoria (Tópico)" 
       TextColor="#333333"
       FontSize="16"
       FontAttributes="Bold"
       Margin="5,15,5,0"/>

            <Border Stroke="#004AAD"
        StrokeThickness="2"
        BackgroundColor="White"
        Padding="15,0"
        StrokeShape="RoundRectangle 15"
        HeightRequest="50">
                <Grid ColumnDefinitions="*, Auto">
                    <Picker ItemsSource="{Binding ListaTopicos}" 
                ItemDisplayBinding="{Binding Name}"
                SelectedItem="{Binding TopicoSelecionado}"
                TextColor="Black"
                FontSize="15"
                VerticalOptions="Center"
                BackgroundColor="Transparent"/>

                    <Image Grid.Column="1" 
               Source="pencil_icon.png" 
               HeightRequest="20" 
               WidthRequest="20"
               VerticalOptions="Center"/>
                </Grid>
            </Border>

            <Label Text="Conteúdo" 
                   TextColor="#333333"
                   FontSize="16"
                   FontAttributes="Bold"
                   Margin="5,0"/>

            <Border Stroke="#004AAD"
                    StrokeThickness="2"
                    BackgroundColor="White"
                    Padding="15,5"
                    StrokeShape="RoundRectangle 15">
                <Grid RowDefinitions="Auto, *">
                    <Image Source="pencil_icon.png" 
                           HeightRequest="18" 
                           HorizontalOptions="End" 
                           Margin="5"/>
                    <Editor Grid.Row="1"
                            Text="{Binding Artigo.ContentBody}" 
                            Placeholder="Digite o conteúdo detalhado aqui..."
                            PlaceholderColor="Gray"
                            TextColor="#004AAD"
                            FontSize="14"
                            HeightRequest="250"
                            AutoSize="Disabled" />
                </Grid>
            </Border>

            <Button Text="Salvar Alterações" 
                    BackgroundColor="#004AAD" 
                    TextColor="White"
                    FontAttributes="Bold"
                    FontSize="16"
                    CornerRadius="30"
                    HeightRequest="55"
                    Margin="0,30,0,20"
                    Command="{Binding SalvarCommand}">
                <Button.Shadow>
                    <Shadow Brush="Black" Offset="0,5" Radius="10" Opacity="0.1"/>
                </Button.Shadow>
            </Button>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>