<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AppEnfermagem.Views.ApresentacaoPage"
             BackgroundColor="#f8f8f8"
             NavigationPage.HasNavigationBar="False">

    <Grid>

        <!-- TOPO MENU -->
        <HorizontalStackLayout
            Spacing="15"
            Padding="20,20,0,0"
            HorizontalOptions="Start"
            VerticalOptions="Start">

            <Image Source="bars_png.png"
                   HeightRequest="28"
                   WidthRequest="28" />

            <Image Source="admin_png.png"
                   HeightRequest="28"
                   WidthRequest="28" />
        </HorizontalStackLayout>

        <!-- CONTEÚDO CENTRAL -->
        <VerticalStackLayout
            Spacing="25"
            HorizontalOptions="Center"
            VerticalOptions="Center"
            MaximumWidthRequest="480"
            Padding="20,80,20,40">

            <!-- LOGO -->
            <Grid WidthRequest="220"
                  HeightRequest="220"
                  HorizontalOptions="Center">

                <Image Source="logo.jpg"
                       Aspect="AspectFill"
                       WidthRequest="220"
                       HeightRequest="220">
                    <Image.Clip>
                        <EllipseGeometry Center="110,110"
                      RadiusX="110"
                      RadiusY="110" />
                    </Image.Clip>
                </Image>

                <Ellipse Stroke="#1a5276"
                         StrokeThickness="2"
                         Fill="Transparent"/>
            </Grid>

            <!-- TEXTO 1 -->
            <Label Text="Apoio à prática assistencial"
                   FontSize="20"
                   FontAttributes="Italic"
                   TextColor="#004AAD"
                   HorizontalTextAlignment="Center" />

            <!-- TEXTO 2 -->
            <Label Text="Conhecimento e prática na palma da mão. Seu suporte diário em Enfermagem"
                   FontSize="22"
                   TextColor="#004AAD"
                   HorizontalTextAlignment="Center" />

            <!-- BOTÃO -->
            <Button Text="Saiba mais"
                    BackgroundColor="#004AAD"
                    TextColor="White"
                    CornerRadius="25"
                    HeightRequest="48"
                    WidthRequest="180"
                    HorizontalOptions="Center"
                    Margin="0,60,0,0"
                    Clicked="SaibaMais_Clicked"/>

        </VerticalStackLayout>

    </Grid>

</ContentPage>
